# ============================================================
# SkillNarrate — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Find these in: Supabase Dashboard → Project → Settings → API
# ------------------------------------------------------------

# The public URL of your Supabase project (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key — used by the browser client (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# The service role key — ONLY used server-side, bypasses Row Level Security
# WARNING: never expose this in the browser or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# IBM WATSONX.AI
# Find these in: IBM Cloud → watsonx.ai project → Manage → API access
# ------------------------------------------------------------

# Your IBM Cloud IAM API key (used to get a temporary bearer token)
WATSONX_API_KEY=your-watsonx-api-key

# Your watsonx.ai project ID (visible in the project URL)
WATSONX_PROJECT_ID=your-watsonx-project-id

# The regional base URL for the watsonx.ai API
# e.g. https://us-south.ml.cloud.ibm.com  or  https://eu-de.ml.cloud.ibm.com
WATSONX_BASE_URL=https://us-south.ml.cloud.ibm.com

# ------------------------------------------------------------
# RESEND (transactional email)
# Find this in: Resend Dashboard → API Keys
# ------------------------------------------------------------

RESEND_API_KEY=your-resend-api-key

# The "from" address for all outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------

# The canonical URL of your app (no trailing slash)
# Use http://localhost:3000 for local dev, your Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
