# ============================================================
# SkillNarrate — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Find these in: Supabase Dashboard → Project → Settings → API
# ------------------------------------------------------------

# The public URL of your Supabase project (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The anon/public key — used by the browser client (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# The service role key — ONLY used server-side, bypasses Row Level Security
# WARNING: never expose this in the browser or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# GOOGLE GEMINI
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier available — no billing required to start.
# ------------------------------------------------------------

# Your Gemini API key — SERVER-ONLY, never expose to the browser
GEMINI_API_KEY=your-gemini-api-key

# ------------------------------------------------------------
# RESEND (transactional email)
# Find this in: Resend Dashboard → API Keys
# ------------------------------------------------------------

RESEND_API_KEY=your-resend-api-key

# The "from" address for all outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------

# The canonical URL of your app (no trailing slash)
# Use http://localhost:3000 for local dev, your Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
